# Backend Environment Variables

# Express Server Port
PORT=5000

# Supabase (PostgreSQL) Connection String
DATABASE_URL=postgresql://postgres.your_project_id:your_password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Allowed Frontend URL for CORS (e.g. your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Secret Key for JWT token signing
JWT_SECRET=your_jwt_secret_key_here

# AES Field-Level Encryption Key (32-byte hex string)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Nodemailer SMTP Email Settings (Optional - for email notifications/resets)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
